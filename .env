# Babylon Testnet Configuration
# Copy this file to .env and fill in your values

# Network Configuration
BABYLON_CHAIN_ID=bbn-test-5
BABYLON_RPC_NODE=https://babylon-testnet-rpc.polkachu.com
BABYLON_GAS_PRICES=0.025ubbn

# Your Pool Configuration
BABYLON_POOL_ADDRESS=bbn1hkmstu883spzwj4k92g90fga3jv3n7ywswn6yr5nq3j4gas

# Your Key Configuration
BABYLON_KEY_NAME=my-key

# Contract Configuration (you need to fill these in)
BABYLON_UNDERLYING_TOKEN=bbn1...  # CW20 token address users will deposit
BABYLON_MANAGER=bbn1...           # Address with vault management privileges
BABYLON_ORACLE=bbn1...            # Address authorized to update price feeds
BABYLON_TOWER_INCENTIVES=bbn1...  # Astroport incentives contract address

# Optional Configuration
# BABYLON_MARKETING=bbn1...       # Marketing role address (optional)
# BABYLON_PROJECT_URL=https://your-project.com
# BABYLON_DESCRIPTION=Automated LP vault for Babylon testnet
