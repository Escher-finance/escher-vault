# Load Nix dev environment automatically when entering the repo
use flake

# Project environment variables (override as needed)
export CHAIN_ID=${CHAIN_ID:=bbn-test-5}
export RPC=${RPC:=https://babylon-testnet-rpc.polkachu.com}
export LCD=${LCD:=https://babylon-testnet-api.polkachu.com}

# Frontend (Vite) env vars (Vite only exposes VITE_* to the client)
export VITE_CHAIN_ID=${VITE_CHAIN_ID:=$CHAIN_ID}
export VITE_RPC=${VITE_RPC:=$RPC}
export VITE_REST=${VITE_REST:=$LCD}
# Set your default deployed contract address here if desired
export VITE_CONTRACT_ADDR=${VITE_CONTRACT_ADDR:=}

# If there is a frontend/.env.local, load it as overrides for local dev
dotenv_if_exists frontend/.env.local

echo "direnv: loaded nix shell and env (CHAIN_ID=$CHAIN_ID, RPC=$RPC)"
#!/usr/bin/env bash
# Automatically load Nix development environment
use flake

# Load environment variables if .env file exists
if [ -f .env ]; then
    export $(cat .env | grep -v '^#' | xargs)
fi

# Set Babylon-specific environment variables
export BABYLON_CHAIN_ID=${BABYLON_CHAIN_ID:-"bbn-test-5"}
export BABYLON_RPC_NODE=${BABYLON_RPC_NODE:-"https://babylon-testnet-rpc.polkachu.com"}
export BABYLON_GAS_PRICES=${BABYLON_GAS_PRICES:-"0.025ubbn"}
export BABYLON_POOL_ADDRESS=${BABYLON_POOL_ADDRESS:-"bbn1hkmstu883spzwj4k92g90fga3jv3n7ywswn6yr5nq3j4gas"}

echo "🌍 Environment loaded:"
echo "  Chain ID: $BABYLON_CHAIN_ID"
echo "  RPC Node: $BABYLON_RPC_NODE"
echo "  Gas Prices: $BABYLON_GAS_PRICES"
echo "  Pool Address: $BABYLON_POOL_ADDRESS"
